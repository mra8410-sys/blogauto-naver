{
  "name": "blogauto-naver",
  "version": "0.1.0",
  "description": "Windows desktop automation console for Naver Blog publishing through codex.cmd.",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "start:runtime": "set BLOGAUTO_RUNTIME_ROOT=%CD%\\dist\\runtime&& electron .",
    "start:runtime:autorun": "set BLOGAUTO_RUNTIME_ROOT=%CD%\\dist\\runtime&& set BLOGAUTO_AUTOSTART=1&& electron .",
    "run:saved": "node scripts/run-saved-job.js",
    "publish:latest": "node scripts/publish-latest-job.js",
    "check": "node scripts/check.js",
    "dist": "electron-builder --win portable && node scripts/prepare-dist-runtime.js"
  },
  "build": {
    "appId": "com.local.blogauto.naver",
    "productName": "Naver Blog Automator",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "runtime-template",
        "to": "runtime"
      }
    ],
    "win": {
      "target": [
        "portable"
      ],
      "artifactName": "Naver-Blog-Automator-${version}.${ext}"
    }
  },
  "dependencies": {
    "playwright-core": "^1.45.0"
  },
  "devDependencies": {
    "@openai/codex": "^0.141.0",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  }
}
